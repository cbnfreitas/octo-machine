digraph uma_noite_de_trabalho {
  graph [rankdir=LR, fontsize=10, label="Uma Noite de Trabalho — nós por local (cores); finais em vermelho (duplo); indefinido = cinza claro via propagação"];
  node [shape=ellipse, style=filled, fontname="Arial", fontsize=9];
  edge [color="#334155"];
  START [shape=cds, fillcolor="#dbeafe", label="START"];
  START -> "1";

  subgraph cluster_legend {
    label="Legenda de cores";
    style=filled;
    color=lightgrey;
    node [shape=box, style=filled, fontsize=9];
    leg_bedroom [label="Quarto (gen.)", fillcolor="#7dd3fc"];
    leg_cellar [label="Porão", fillcolor="#78716c"];
    leg_combat [label="Combate (cena)", fillcolor="#fb923c"];
    leg_entry [label="Entrada (janela)", fillcolor="#bae6fd"];
    leg_exterior [label="Rua / fuga / casa", fillcolor="#4ade80"];
    leg_hall [label="Salão", fillcolor="#c4b5fd"];
    leg_kitchen [label="Cozinha", fillcolor="#fbbf24"];
    leg_living [label="Sala de estar", fillcolor="#ddd6fe"];
    leg_ownerroom [label="Quarto do dono", fillcolor="#0ea5e9"];
    leg_pantry [label="Despensa", fillcolor="#84cc16"];
    leg_prison [label="Cela / prisão", fillcolor="#64748b"];
    leg_stairs [label="Escadas / patamar", fillcolor="#d6d3d1"];
    leg_storage [label="Depósito (baixo da despensa)", fillcolor="#a3e635"];
    leg_story_end [label="Fim (evento mágico)", fillcolor="#f9a8d4"];
    leg_vestibule [label="Vestíbulo", fillcolor="#facc15"];
    leg_watchroom [label="Quarto do vigia", fillcolor="#38bdf8"];
    leg_final [label="Final da aventura", fillcolor="#fca5a5", peripheries=2];
  }

