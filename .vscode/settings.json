{
  "cursor.composer.shouldAutoAcceptDiffs": true,
  "cursor.chat.autoApplyEdits": true,
  "cursor.mcp.enabled": false,
  "liveServer.settings.NoBrowser": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "vue"
  ],
  "eslint.run": "onType",
  "eslint.workingDirectories": [
    {
      "directory": "frontend",
      "changeProcessCWD": true
    }
  ],
  "python.analysis.diagnosticMode": "workspace",
  "python.analysis.typeCheckingMode": "basic",
  "python.defaultInterpreterPath": "${workspaceFolder}/backend/.venv/Scripts/python.exe",
  "python.venvPath": "${workspaceFolder}/backend",
  "python.terminal.activateEnvironment": true,
  "python.analysis.diagnosticSeverityOverrides": {
    "reportMissingImports": "none",
    "reportMissingModuleSource": "none"
  },
  "cursorpyright.analysis.diagnosticMode": "workspace",
  "cursorpyright.analysis.diagnosticSeverityOverrides": {
    "reportMissingImports": "none",
    "reportMissingModuleSource": "none"
  },
  "cursorpyright.analysis.typeCheckingMode": "basic"
}
